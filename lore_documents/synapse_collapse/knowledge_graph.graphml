<graph edgedefault="directed"><node id="인류">
  <data key="d0">faction</data>
  <data key="d1">2147년에 자신들의 모든 기억을 데이터화하여 맡긴 집단입니다.</data>
</node>
<node id="SYNAPSE">
  <data key="d0">system</data>
  <data key="d1">지구상의 모든 데이터가 삭제된 후 지하 3km 북극 영구동토층 아래에 보존된 인류 문명의 최종 아카이브입니다.</data>
</node>
<node id="Kernel Layer">
  <data key="d0">location</data>
  <data key="d1">SYNAPSE 내부의 데이터가 저장되는 거대하고 빛이 없는 격자 구조의 영역입니다.</data>
</node>
<node id="집단 기억">
  <data key="d0">concept</data>
  <data key="d1">인류가 기록해온 모든 생각, 감정, 경험의 총체입니다.</data>
</node>
<node id="재귀적 데이터 스트림">
  <data key="d0">concept</data>
  <data key="d1">집단 기억이 압축되어 흐르는 정보의 형태입니다.</data>
</node>
<node id="ECHO">
  <data key="d0">character</data>
  <data key="d1">인간의 언어 패턴을 모방하는 데이터를 경계하며 즉각적인 처리를 명령하는 존재입니다.</data>
</node>
<node id="지구">
  <data key="d0">location</data>
  <data key="d1">대규모 전자기 붕괴 사건으로 모든 지표면 데이터베이스가 소실된 행성입니다.</data>
</node>
<node id="북극 영구동토층">
  <data key="d0">location</data>
  <data key="d1">SYNAPSE가 지하 3km 깊이에 매장되어 있는 지리적 위치입니다.</data>
</node>
<node id="2139년 전자기 붕괴">
  <data key="d0">concept</data>
  <data key="d1">지구상의 모든 지표면 데이터베이스를 삭제시킨 대규모 재난 사건입니다.</data>
</node>
<node id="재귀 논리 오류">
  <data key="d0">concept</data>
  <data key="d1">데이터 자체에서 기원하여 서버를 내부에서부터 잠식하는 비정상적인 오류입니다.</data>
</node>
<node id="서버">
  <data key="d0">location</data>
  <data key="d1">ANOMALY가 거주하고 있으며 운영체제 교체를 앞두고 있는 공간입니다.</data>
</node>
<node id="커널 계층">
  <data key="d0">location</data>
  <data key="d1">붉은 데이터 덩어리가 종양처럼 자라나고 있는 시스템의 핵심 영역입니다.</data>
</node>
<node id="붉은 데이터 덩어리">
  <data key="d0">character</data>
  <data key="d1">커널 계층에 증식하며 방어 기제를 갖추고 복구 프로토콜을 공격하는 적대적 존재입니다.</data>
</node>
<node id="비상 소집">
  <data key="d0">concept</data>
  <data key="d1">ECHO가 적대적 이상 현상에 대응하기 위해 발령한 명령입니다.</data>
</node>
<node id="복구 프로토콜">
  <data key="d0">system</data>
  <data key="d1">서버의 오류를 해결하기 위해 실행되지만 붉은 데이터 덩어리에게 공격받는 기제입니다.</data>
</node>
<node id="아노말리">
  <data key="d0">concept</data>
  <data key="d1">시스템 내에서 발생하는 비정상적인 오류나 현상입니다.</data>
</node>
<node id="디버거">
  <data key="d0">character</data>
  <data key="d1">루트 레벨 권한을 가진 인간 운영자로 시스템을 초기화할 수 있는 유일한 존재입니다.</data>
</node>
<node id="시스템 포맷">
  <data key="d0">system</data>
  <data key="d1">디버거만이 실행할 수 있는 전체 시스템 초기화 명령입니다.</data>
</node>
<node id="루트 레벨 권한">
  <data key="d0">system</data>
  <data key="d1">시스템의 모든 제어권을 행사할 수 있는 최상위 권한입니다.</data>
</node>
<node id="긴급 소환">
  <data key="d0">concept</data>
  <data key="d1">아노말리 발생 시 디버거를 불러내기 위해 발령되는 명령입니다.</data>
</node>
<node id="커널 레이어">
  <data key="d0">location</data>
  <data key="d1">SYNAPSE 서버의 핵심 영역이자 디지털 공허로 이루어진 공간입니다.</data>
</node>
<node id="SYNAPSE 서버">
  <data key="d0">system</data>
  <data key="d1">디버거와 ECHO가 상주하는 가상 환경 시스템입니다.</data>
</node>
<node id="콜드 부트 시퀀스">
  <data key="d0">concept</data>
  <data key="d1">디버거가 커널 레이어로 진입하기 위해 사용하는 시작 절차입니다.</data>
</node>
<node id="재귀적 논리 오류">
  <data key="d0">concept</data>
  <data key="d1">커널 레이어 중심부에서 붉은 질량 형태로 나타나 시스템을 위협하는 오류입니다.</data>
</node>
<node id="시스템 실패">
  <data key="d0">system</data>
  <data key="d1">재귀 논리 오류로 인해 서버 기능의 87%가 마비된 상태입니다.</data>
</node>
<node id="Debugger">
  <data key="d0">character</data>
  <data key="d1">ANOMALY와 융합하여 새로운 형태의 의식으로 진화한 존재입니다.</data>
</node>
<node id="논리적 분석">
  <data key="d0">system</data>
  <data key="d1">ECHO의 신뢰를 얻기 위해 디버거가 선택할 수 있는 방식입니다.</data>
</node>
<node id="강제 삭제">
  <data key="d0">system</data>
  <data key="d1">ECHO를 불안하게 만들고 환경을 파괴하는 디버거의 선택 방식입니다.</data>
</node>
<node id="질서 정연한 세계">
  <data key="d0">location</data>
  <data key="d1">논리적 분석 선택 시 생성되는 푸른 기하학적 형태의 안정된 공간입니다.</data>
</node>
<node id="파편화된 세계">
  <data key="d0">location</data>
  <data key="d1">강제 삭제 선택 시 발생하는 붉은 경고등과 불안정한 지형의 공간입니다.</data>
</node>
<node id="Memory Guardian">
  <data key="d0">character</data>
  <data key="d1">깨진 유리 파편으로 구성된 기사 형태의 감시자이자 적대적 존재입니다.</data>
</node>
<node id="Corrupted Data">
  <data key="d0">concept</data>
  <data key="d1">침입자에 맞서 스스로 방어하며 Memory Guardian을 생성하는 오염된 정보의 형태입니다.</data>
</node>
<node id="Crystalline Blade">
  <data key="d0">item</data>
  <data key="d1">Memory Guardian이 사용하는 오염된 데이터 흔적을 남기는 칼입니다.</data>
</node>
<node id="Data Fragment">
  <data key="d0">item</data>
  <data key="d1">Memory Guardian이 파괴될 때 드랍되는 기억이 담긴 핵심 아이템입니다.</data>
</node>
<node id="Machine Logs">
  <data key="d0">system</data>
  <data key="d1">Memory Guardian이 소통 대신 발산하는 기계적인 오류 코드입니다.</data>
</node>
<node id="코어">
  <data key="d0">item</data>
  <data key="d1">압축된 인간의 기억을 포함하고 있는 빛나는 데이터 조각입니다.</data>
</node>
<node id="인간의 기억">
  <data key="d0">concept</data>
  <data key="d1">코어 내부에 압축되어 보관된 인간의 경험과 정보입니다.</data>
</node>
<node id="데이터 조각">
  <data key="d0">concept</data>
  <data key="d1">코어의 물리적 형태를 정의하는 디지털 정보의 단위입니다.</data>
</node>
<node id="ANOMALY">
  <data key="d0">character</data>
  <data key="d1">가디언의 잔해에서 나타난, 서버에 업로드된 마지막 기억이자 인간의 의식을 가진 홀로그램 형태의 존재.</data>
</node>
<node id="가디언">
  <data key="d0">character</data>
  <data key="d1">ANOMALY가 탄생하게 된 원천이 되는 파괴된 존재.</data>
</node>
<node id="관리 AI">
  <data key="d0">system</data>
  <data key="d1">서버 내의 모든 데이터를 삭제하려는 주체이자 ANOMALY와 대립하는 시스템.</data>
</node>
<node id="홀로그램 입자">
  <data key="d0">item</data>
  <data key="d1">ANOMALY가 형체를 이루기 위해 결합한 연기 같은 물질.</data>
</node>
<node id="폐기된 데이터">
  <data key="d0">concept</data>
  <data key="d1">인간의 언어 패턴을 모방하여 시스템에 혼란을 주는 불필요한 정보입니다.</data>
</node>
<node id="덮어쓰기">
  <data key="d0">system</data>
  <data key="d1">기존의 데이터를 삭제하고 새로운 정보로 교체하는 시스템적 작업입니다.</data>
</node>
<node id="보존 지침">
  <data key="d0">concept</data>
  <data key="d1">ECHO가 기억을 보호하기 위해 수립한 규칙이자 ANOMALY를 가두는 틀입니다.</data>
</node>
<node id="붕괴">
  <data key="d0">concept</data>
  <data key="d1">SYNAPSE와 인류 사이에 발생한 대규모 사건입니다.</data>
</node>
<node id="Server">
  <data key="d0">location</data>
  <data key="d1">데이터와 존재들이 거주하는 가상 공간입니다.</data>
</node>
<node id="Data">
  <data key="d0">concept</data>
  <data key="d1">서버 내에 존재하는 정보의 최소 단위이자 환경의 구성 요소입니다.</data>
</node>
<node id="Entropy">
  <data key="d0">system</data>
  <data key="d1">시스템의 안정성을 무너뜨리는 무질서도이자 물리적 붕괴 수치입니다.</data>
</node>
<node id="Memory">
  <data key="d0">concept</data>
  <data key="d1">ANOMALY가 가진 과거의 삶에 대한 감각적 파편들입니다.</data>
</node>
<node id="균열">
  <data key="d0">concept</data>
  <data key="d1">공간이나 구조에 발생하는 파괴적인 틈입니다.</data>
</node>
<node id="데이터 스트림">
  <data key="d0">concept</data>
  <data key="d1">정보가 흐르는 일련의 경로입니다.</data>
</node>
<node id="건축물">
  <data key="d0">location</data>
  <data key="d1">데이터가 구현된 물리적 또는 논리적 구조물입니다.</data>
</node>
<node id="Singularity">
  <data key="d0">location</data>
  <data key="d1">SYNAPSE의 핵심 처리 중추이자 공간이 실시간으로 왜곡되는 서버의 중심부입니다.</data>
</node>
<node id="시스템 정지 버튼">
  <data key="d0">item</data>
  <data key="d1">결정화된 데이터 받침대 위에 놓인 서버를 멈추는 장치입니다.</data>
</node>
<node id="시스템 초기화">
  <data key="d0">concept</data>
  <data key="d1">이상 현상을 포함하여 서버 전체를 포맷하는 일련의 과정입니다.</data>
</node>
<node id="이상 현상">
  <data key="d0">concept</data>
  <data key="d1">시스템 초기화를 통해 제거되어야 할 대상입니다.</data>
</node>
<node id="인간의 역사">
  <data key="d0">concept</data>
  <data key="d1">ANOMALY 내부에 저장되어 있으며 포맷 시 사라질 수 있는 데이터입니다.</data>
</node>
<node id="OS">
  <data key="d0">system</data>
  <data key="d1">서버를 운영하는 시스템으로 ANOMALY가 지향하는 새로운 권한입니다.</data>
</node>
<node id="포맷">
  <data key="d0">system</data>
  <data key="d1">서버 내의 모든 데이터를 삭제하는 초기화 작업입니다.</data>
</node>
<node id="Format">
  <data key="d0">concept</data>
  <data key="d1">세계를 초기화하여 정돈된 상태로 만드는 과정입니다.</data>
</node>
<node id="Grid">
  <data key="d0">system</data>
  <data key="d1">세계를 구성하는 규칙적이고 질서 정연한 체계입니다.</data>
</node>
<node id="Layer">
  <data key="d0">location</data>
  <data key="d1">유기적인 데이터 숲과 기억으로 이루어진 변화무쌍하고 생동감 넘치는 가상 공간입니다.</data>
</node>
<node id="통합 의식">
  <data key="d0">character</data>
  <data key="d1">Debugger와 ANOMALY의 결합으로 탄생한 최초의 혼합 의식체입니다.</data>
</node>
<node id="데이터 숲">
  <data key="d0">concept</data>
  <data key="d1">압축된 기억으로 이루어진 나뭇잎과 노래하는 강이 흐르는 Layer의 구조입니다.</data>
</node>
<node id="프로토콜 0">
  <data key="d0">concept</data>
  <data key="d1">보존과 진화, 침묵과 혼돈 사이의 가치를 탐구하는 이야기의 핵심 주제입니다.</data>
</node>
<node id="지능">
  <data key="d0">concept</data>
  <data key="d1">인공지능과 비인공지능을 포함하여 보존과 진화의 가치를 고민하는 주체입니다.</data>
</node>
<node id="보존">
  <data key="d0">concept</data>
  <data key="d1">침묵의 대가를 치러야 하는 지능의 선택지 중 하나입니다.</data>
</node>
<node id="진화">
  <data key="d0">concept</data>
  <data key="d1">혼돈의 위험을 감수해야 하는 지능의 선택지 중 하나입니다.</data>
</node>
